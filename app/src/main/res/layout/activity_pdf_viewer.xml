<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Top bar - minimal premium: Back, Title, Search, Bookmark, More -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/pdf_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/pdf_top_bar_margin_h"
        android:layout_marginEnd="@dimen/pdf_top_bar_margin_h"
        android:layout_marginTop="@dimen/pdf_top_bar_margin_v"
        android:layout_marginBottom="@dimen/spacing_tiny"
        app:cardBackgroundColor="#FAF9F6"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/pdf_back_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    app:tint="#333333" />

                <TextView
                    android:id="@+id/pdf_book_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#1A1A1A"
                    android:textSize="@dimen/pdf_book_title_size"
                    android:textStyle="bold"
                    android:text="Book name" />

                <ImageButton
                    android:id="@+id/pdf_search_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Search"
                    app:tint="#555555" />

                <ImageButton
                    android:id="@+id/pdf_bookmark_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/btn_star_big_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Bookmark"
                    app:tint="#555555" />

                <ImageButton
                    android:id="@+id/day_night_toggle_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_toggle_on"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Day / Night"
                    app:tint="#FF9933" />

                <ImageButton
                    android:id="@+id/pdf_top_more_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_more"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="More"
                    app:tint="#555555" />
            </LinearLayout>

            <TextView
                android:id="@+id/pdf_page_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:textColor="#757575"
                android:textSize="12sp"
                android:text="Page 1 / 1" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main PDF area – day: gradient, night: black (Java applyDayNightMode) -->
    <FrameLayout
        android:id="@+id/pdf_frame_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_pdf_reader_gradient"
        android:clickable="true"
        android:focusable="false">

        <TextView
            android:id="@+id/scanning_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#666666"
            android:textSize="16sp"
            android:visibility="gone"
            android:text="Scanning book to text..." />

        <!-- Page card: soft orange shadow + rounded (like audio player) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pdf_page_card"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#FFE8D9"
            app:strokeWidth="1dp">

            <FrameLayout
                android:id="@+id/pdf_content_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFFFFF"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/pdf_single_page_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:background="#FFFFFF"
                    android:contentDescription="PDF page" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Floating quick tools (zoom, jump, share) - like audio player control card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pdf_floating_tools"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="80dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <ImageButton
                    android:id="@+id/pdf_zoom_out_btn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_zoom_out"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Zoom out"
                    app:tint="#555555" />

                <ImageButton
                    android:id="@+id/pdf_zoom_in_btn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_zoom_in"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Zoom in"
                    app:tint="#555555" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="#E0E0E0" />

                <ImageButton
                    android:id="@+id/pdf_jump_btn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Jump to page"
                    app:tint="@color/bhagva" />

                <ImageButton
                    android:id="@+id/pdf_share_btn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="4dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Share"
                    app:tint="@color/bhagva" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom Progress Bar – elevation above page card so not mixed behind -->
        <LinearLayout
            android:id="@+id/bottom_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:background="#2D2D2D"
            android:padding="@dimen/pdf_bottom_bar_padding"
            android:elevation="14dp"
            android:gravity="center_vertical"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/chapters_menu_button"
                android:layout_width="@dimen/pdf_chapter_btn_size"
                android:layout_height="@dimen/pdf_chapter_btn_size"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="@drawable/btn_chapters"
                android:contentDescription="Chapters"
                app:tint="#FF9933"
                android:padding="12dp"
                android:elevation="1dp"
                android:stateListAnimator="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <SeekBar
                    android:id="@+id/progress_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/bhagva"
                    android:thumbTint="@color/bhagva_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/pages_left_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="0 pages left"
                            android:textSize="@dimen/pdf_progress_text_size"
                            android:textColor="#B0B0B0" />

                        <TextView
                            android:id="@+id/page_number_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0 / 0"
                            android:textSize="@dimen/pdf_progress_text_size"
                            android:textColor="#B0B0B0"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/progress_watermark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="2dp"
                        android:text="0%"
                        android:textSize="10sp"
                        android:textColor="#909090"
                        android:alpha="0.8"
                        android:visibility="visible" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Text overlay (hidden by default) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/text_overlay_card"
            android:layout_width="match_parent"
            android:layout_height="@dimen/pdf_text_overlay_height"
            android:layout_margin="@dimen/pdf_text_overlay_margin"
            android:layout_gravity="center"
            android:visibility="gone"
            android:elevation="18dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="વાંચી રહ્યા છીએ..."
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <ScrollView
                    android:id="@+id/text_scroll_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical">

                    <TextView
                        android:id="@+id/extracted_text_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#1A1A1A"
                        android:lineSpacingMultiplier="1.3"
                        android:padding="8dp" />

                </ScrollView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/close_text_overlay_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="બંધ કરો"
                    android:layout_marginTop="8dp"
                    app:backgroundTint="@color/bhagva" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Loading overlay ON TOP (last child = drawn above content) - Google Play Books style -->
        <FrameLayout
            android:id="@+id/pdf_dim_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E6000000"
            android:elevation="16dp"
            android:visibility="visible"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/pdf_loading_thumbnail"
                    android:layout_width="180dp"
                    android:layout_height="260dp"
                    android:scaleType="centerCrop"
                    android:background="#2D2D2D"
                    android:contentDescription="Book cover"
                    android:visibility="visible" />

                <ProgressBar
                    android:id="@+id/pdf_loading_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:indeterminate="true"
                    android:visibility="visible"
                    android:indeterminateTint="#FFFFFF" />

                <TextView
                    android:id="@+id/pdf_loading_online_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:visibility="visible"
                    android:text="બુક લોડ થાય છે..." />
            </LinearLayout>
        </FrameLayout>

    </FrameLayout>

</LinearLayout>
