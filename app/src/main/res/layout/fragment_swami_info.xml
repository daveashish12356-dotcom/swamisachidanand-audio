<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:clipToPadding="false"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_large"
        android:paddingEnd="@dimen/spacing_large"
        android:paddingTop="@dimen/spacing_xlarge"
        android:paddingBottom="@dimen/spacing_xlarge">

        <!-- Header: Large photo + intro (Gujarati Vishwakosh style) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/swami_avatar"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/SwamiAvatarShape"
                    app:strokeColor="@color/deep_saffron"
                    app:strokeWidth="2dp"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="સ્વામી સચ્ચિદાનંદ"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:text="જ. ૨૨ એપ્રિલ ૧૯૩૨, મુજપુર, જિ. પાટણ"
                    android:textSize="13sp"
                    android:textColor="?attr/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="@string/swami_intro"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="ભક્તિ નિકેતન આશ્રમ · દંતાલી, ઊંઝા, કોબા (ગાંધીનગર)"
                    android:textSize="13sp"
                    android:textColor="@color/deep_saffron"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- જીવન (Life) - Gujarati Vishwakosh -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="જીવન — પ્રારંભિક જીવન અને આધ્યાત્મિક વિકાસ"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_early_life"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_early_life"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_spiritual"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- રચનાઓ (Works) - Gujarati Vishwakosh -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swami_literature_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_literature"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- સન્માન (Honours) - Gujarati Vishwakosh -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swami_awards_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_awards"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- વિચારધારા (Philosophy) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swami_philosophy_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_philosophy"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="સ્રોત: ગુજરાતી વિશ્વકોશ"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorTertiary"
                    android:fontStyle="italic" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- સામાજિક પ્રયાસો -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swami_social_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_social"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- વારસો અને પ્રભાવ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swami_legacy_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/swami_legacy"
                    android:textSize="14sp"
                    android:textColor="?attr/text_secondary"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

