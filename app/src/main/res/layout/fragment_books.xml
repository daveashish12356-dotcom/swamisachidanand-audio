<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_books_gradient">

<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/books_swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.core.widget.NestedScrollView
    android:id="@+id/books_nested_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Search Bar - global, same on all pages. Filter shown for Books. -->
    <include
        layout="@layout/layout_global_search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/books_search_bar_include" />

    <!-- Category Chips - horizontal scroll -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/category_chips_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_medium"
        android:paddingEnd="@dimen/spacing_medium"
        android:paddingBottom="@dimen/spacing_normal"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- Loading line -->
    <TextView
        android:id="@+id/books_loading_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="44dp"
        android:visibility="gone"
        android:paddingStart="@dimen/spacing_medium"
        android:paddingEnd="@dimen/spacing_medium"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="લોડ થાય છે…"
        android:textSize="16sp"
        android:textColor="#616161"
        android:gravity="center"
        android:background="#F5F5F5" />

    <!-- Search results line (when user types in search bar) -->
    <LinearLayout
        android:id="@+id/books_search_results_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/section_title_margin_bottom"
        android:visibility="gone">

        <TextView
            android:id="@+id/books_search_results_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 મળેલી પુસ્તકો"
            android:textSize="@dimen/section_title_size"
            android:textStyle="bold"
            android:textColor="?attr/text_primary"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/books_search_results_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:paddingEnd="8dp"
            android:scrollbars="none"
            tools:listitem="@layout/item_book_home" />
    </LinearLayout>

    <!-- Popular Books Section -->
    <LinearLayout
        android:id="@+id/popular_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/section_title_margin_bottom">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="લોકપ્રિય પુસ્તકો"
            android:textSize="@dimen/section_title_size"
            android:textStyle="bold"
            android:textColor="?attr/text_primary"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/popular_recycler"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:paddingEnd="8dp"
            android:scrollbars="none"
            tools:listitem="@layout/item_book_home" />
    </LinearLayout>

    <!-- All Books Section Title -->
    <TextView
        android:id="@+id/all_books_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="બધાં પુસ્તકો"
        android:textSize="@dimen/section_title_size"
        android:textStyle="bold"
        android:textColor="?attr/text_primary"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="12dp" />

    <!-- Books Grid -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="400dp">

        <View
            android:id="@+id/eye_protection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#60FFD700"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/books_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingTop="@dimen/spacing_small"
            android:paddingStart="@dimen/spacing_medium"
            android:paddingEnd="@dimen/spacing_medium"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

        <LinearLayout
            android:id="@+id/empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/empty_icon_size"
                android:layout_height="@dimen/empty_icon_size"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/deep_saffron"
                android:alpha="0.6"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No books found"
                android:textSize="@dimen/empty_title_size"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/empty_text_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading books..."
                android:textSize="@dimen/empty_message_size"
                android:textColor="#757575" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
</androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</FrameLayout>
