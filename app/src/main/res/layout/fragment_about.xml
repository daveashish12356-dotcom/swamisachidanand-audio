<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_light">

<ScrollView
    android:id="@+id/about_scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="28dp">

        <!-- Sampark – photo thoda niche, color dark, border dikhe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="80dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#E8E8E8"
                app:strokeColor="#BBBBBB"
                app:strokeWidth="2dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/sampark_photo"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sampark_photo"
                    app:shapeAppearanceOverlay="@style/SwamiAvatarShape"
                    app:strokeColor="@color/deep_saffron"
                    app:strokeWidth="2dp"
                    android:contentDescription="સંપર્ક" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/sampark_photo_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/sampark_photo_caption"
                android:textSize="14sp"
                android:textColor="?attr/text_primary"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- YouTube, Facebook, WhatsApp, Telegram – original brand icons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sampark_follow_us"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/text_primary"
            android:gravity="center"
            android:layout_marginBottom="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/sampark_youtube"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="8dp"
                android:src="@drawable/ic_social_youtube"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="YouTube" />
            <ImageView
                android:id="@+id/sampark_facebook"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="8dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_social_facebook"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Facebook" />
            <ImageView
                android:id="@+id/sampark_whatsapp"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="8dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_social_whatsapp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="WhatsApp" />
            <ImageView
                android:id="@+id/sampark_telegram"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="8dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_social_telegram"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Telegram" />
        </LinearLayout>

        <!-- Ashrams Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="આશ્રમો"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/text_primary"
            android:layout_marginBottom="12dp"
            android:gravity="center" />

        <!-- Ashram 1 - Bhaktiniketan -->
        <include layout="@layout/item_ashram"
            android:id="@+id/ashram1" />

        <!-- Ashram 2 - Sadhana Ashram -->
        <include layout="@layout/item_ashram"
            android:id="@+id/ashram2" />

        <!-- Ashram 3 - Vridhashram -->
        <include layout="@layout/item_ashram"
            android:id="@+id/ashram3" />

        <!-- Ashram 4 - Suigam -->
        <include layout="@layout/item_ashram"
            android:id="@+id/ashram4" />

    </LinearLayout>

</ScrollView>

</FrameLayout>

