<?xml version="1.0" encoding="utf-8"?>
<!-- Swagat ke baad: 2 photos round/circle me, crossfade animation -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:gravity="center">

    <!-- Equal width/height = perfect circle -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/photo_banner_1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/header_photo1"
            android:scaleType="centerCrop"
            android:contentDescription="Photo 1"
            app:shapeAppearanceOverlay="@style/SwamiAvatarShape"
            app:strokeColor="@color/deep_saffron"
            app:strokeWidth="2dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/photo_banner_2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/header_photo2"
            android:scaleType="centerCrop"
            android:alpha="0"
            android:contentDescription="Photo 2"
            app:shapeAppearanceOverlay="@style/SwamiAvatarShape"
            app:strokeColor="@color/deep_saffron"
            app:strokeWidth="2dp" />
    </FrameLayout>
</FrameLayout>
