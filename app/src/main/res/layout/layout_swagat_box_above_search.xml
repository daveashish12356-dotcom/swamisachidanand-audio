<?xml version="1.0" encoding="utf-8"?>
<!-- Ek box: हरिः ॐ सुस्वागतम् + Swami icon + search bar. 2 photo nikal diye. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/swagat_box_gradient"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Row 1: हरिः ॐ 🙏 सुस्वागतम् (reference style) + Swami ji ka page icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="हरिः ॐ 🙏 सुस्वागतम्"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C1810"
            android:letterSpacing="0.04"
            android:shadowColor="#40000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="1.5"
            android:maxLines="1"
            android:ellipsize="end" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/global_profile_avatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="21dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#E0D0C0"
            app:strokeWidth="1.5dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/swami_avatar"
                android:scaleType="centerCrop"
                android:contentDescription="@string/app_name"
                app:shapeAppearanceOverlay="@style/SwamiAvatarShape"
                app:strokeColor="@color/deep_saffron"
                app:strokeWidth="1.5dp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Search bar – isi box ke andar, white pill -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="22dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeColor="#E0E0E0"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="52dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/deep_saffron"
                android:layout_marginEnd="12dp"
                android:contentDescription="Search" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/global_search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="28dp"
                android:hint="@string/search_global_hint"
                android:textSize="15sp"
                android:textColorHint="#8A8A8A"
                android:textColor="@color/text_primary"
                android:background="@android:color/transparent"
                android:inputType="text|textAutoComplete|textAutoCorrect"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:singleLine="true"
                android:textCursorDrawable="@null"
                android:gravity="center_vertical" />

            <ImageView
                android:id="@+id/global_clear_search"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#8A8A8A"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Clear" />

            <ImageView
                android:id="@+id/global_mic_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/deep_saffron"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Voice search" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
