<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_audio_header_gradient"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/audio_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/audio_collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@null"
            app:scrimAnimationDuration="280"
            app:titleEnabled="false"
            app:collapsedTitleGravity="center_vertical">

            <!-- Big thumbnail – collapses on scroll, full parallax so no sliver shows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="1.0"
                android:paddingTop="48dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/audio_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:letterSpacing="0.01" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:paddingTop="4dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/audio_detail_thumbnail_container"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        app:cardCornerRadius="75dp"
                        app:cardElevation="12dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="#FFD4B8"
                        app:cardUseCompatPadding="false">

                        <ImageView
                            android:id="@+id/audio_detail_thumbnail_compact"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@drawable/book_placeholder"
                            android:contentDescription="Cover" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Mini player bar – overlay on top, shows when scrolled – part + progress line -->
    <LinearLayout
        android:id="@+id/audio_mini_player_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="@drawable/bg_player_card"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:alpha="0"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Row: thumbnail | part name | play -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="22dp"
                app:strokeWidth="0dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/audio_mini_thumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/book_placeholder"
                    android:contentDescription="Cover" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/audio_mini_part_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/text_primary"
                android:text="ભાગ ચૂંટો" />

            <ImageButton
                android:id="@+id/audio_mini_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_play"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/bhagva" />
        </LinearLayout>

        <!-- Progress line: 0:00 | seek | 0:00 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/audio_mini_time_current"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="10sp"
                android:textColor="@color/bhagva"
                android:textStyle="bold"
                android:gravity="end" />

            <SeekBar
                android:id="@+id/audio_mini_seek"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/bhagva"
                android:thumbTint="@color/bhagva"
                android:paddingStart="0dp"
                android:paddingEnd="0dp" />

            <TextView
                android:id="@+id/audio_mini_time_total"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="10sp"
                android:textColor="#757575"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@drawable/bg_audio_header_gradient"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Player card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_player_card"
                android:padding="14dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/audio_detail_part_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_player_title_bar"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="ભાગ ચૂંટો"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/audio_detail_time_current"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="11sp"
                        android:textColor="@color/bhagva"
                        android:textStyle="bold"
                        android:gravity="end" />

                    <SeekBar
                        android:id="@+id/audio_detail_seek"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:max="1000"
                        android:progress="0"
                        android:progressTint="@color/bhagva"
                        android:thumbTint="@color/bhagva"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp" />

                    <TextView
                        android:id="@+id/audio_detail_time_total"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="11sp"
                        android:textColor="#757575"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp">

                    <ImageButton
                        android:id="@+id/audio_detail_prev"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/audio_prev"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_media_previous"
                        app:tint="#555555" />

                    <ImageButton
                        android:id="@+id/audio_detail_play_btn"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/play_button_gradient"
                        android:padding="14dp"
                        android:contentDescription="@string/audio_play"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@android:color/white" />

                    <ImageButton
                        android:id="@+id/audio_detail_next"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/audio_next"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#555555" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:id="@+id/audio_detail_speed_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minWidth="80dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_speed_btn_visible"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/audio_detail_speed_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_speed"
                            android:contentDescription="ઝડપ"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/audio_detail_speed_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1x ▼"
                            android:textSize="13sp"
                            android:textColor="@color/bhagva"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ભાગો heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:background="@color/bhagva"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/audio_chapters"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/text_primary"
                    android:letterSpacing="0.01" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/audio_detail_parts_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="never"
                android:clipToPadding="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="2dp"
                android:paddingBottom="40dp"
                android:scrollbars="none" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
