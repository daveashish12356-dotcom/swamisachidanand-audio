<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <size
        android:width="32dp"
        android:height="32dp" />
    <gradient
        android:startColor="#FFFEE9D5"
        android:centerColor="#FFF9D3A0"
        android:endColor="#FFEFA55A"
        android:angle="270" />
    <stroke
        android:width="1dp"
        android:color="#33E85D04" />
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>

